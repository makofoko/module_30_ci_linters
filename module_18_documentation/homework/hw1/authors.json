{
  "swagger": "2.0",
  "info": {
    "title": "Authors API",
    "version": "1.0"
  },
  "paths": {
    "/api/authors/": {
      "post": {
        "summary": "Создать автора",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Author" }
          }
        ],
        "responses": {
          "201": { "description": "Автор создан" }
        }
      }
    },
    "/api/authors/{id}": {
      "get": {
        "summary": "Получить автора по ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": {
            "description": "Автор найден",
            "schema": { "$ref": "#/definitions/Author" }
          },
          "404": { "description": "Автор не найден" }
        }
      },
      "delete": {
        "summary": "Удалить автора по ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "integer" }
        ],
        "responses": {
          "200": { "description": "Автор и все его книги удалены" },
          "404": { "description": "Автор не найден" }
        }
      }
    }
  },
  "definitions": {
    "Author": {
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "middle_name": { "type": "string" }
      }
    }
  }
}