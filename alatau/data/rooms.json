@app.route('/')
def home():
    """Основная страница приложения."""
    return render_template_string(HTML_TEMPLATE)

@app.route('/api/book', methods=['POST'])
def book():
    """API для обработки бронирования."""
    data = request.json

    # Прейскурант
    prices = {
        'Chalet Royal': 120000,
        'Crystal Dome': 85000,
        'Forest A-Frame': 65000
    }

    try:
        room_type = data.get('room_type')
        nights = int(data.get('nights', 1))

        # Расчет стоимости на сервере (безопаснее, чем на клиенте)
        total_price = prices.get(room_type, 0) * nights

        # Здесь могла быть логика записи в БД
        print(f"Новое бронирование: {room_type} на {nights} ночей. Сумма: {total_price}")

        return jsonify({
            'status': 'success',
            'total_price': total_price,
            'message': 'Booking confirmed'
        })
    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 400

@app.route('/api/login', methods=['POST'])
def login():
    """Простая имитация авторизации."""
    data = request.json
    username = data.get('username', 'Гость')
    # В реальности тут была бы проверка пароля и сессии
    return jsonify({
        'status': 'success',
        'username': username.upper()
    })

if __name__ == '__main__':
    app.run(debug=True)